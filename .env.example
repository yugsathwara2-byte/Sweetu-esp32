# Copy to .env.local for local development
# On Vercel: Project Settings → Environment Variables

# Your AWS Home Assistant public URL (no trailing slash)
# Example: https://homeassistant.yourdomain.com:8123
HOME_ASSISTANT_URL=

# Long-lived access token from HA Profile → Security
HOME_ASSISTANT_TOKEN=

# Optional: override Gemini conversation agent
HOME_ASSISTANT_AGENT_ID=conversation.google_ai_conversation_2

# Your Postgres Database Connection String (Supabase, Vercel Postgres, Neon, etc.)
# Example: postgresql://username:password@hostname:5432/dbname
POSTGRES_URL=
